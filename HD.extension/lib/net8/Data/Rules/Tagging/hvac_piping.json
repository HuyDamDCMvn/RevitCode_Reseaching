{
  "$schema": "../Schema/TaggingRule.schema.json",
  "id": "hvac_piping_chw_lthw",
  "name": "HVAC Piping - Chilled & Hot Water",
  "version": "1.0.0",
  "description": "Pipe tagging rules for HVAC chilled water and low temperature hot water systems - German standard",
  "enabled": true,
  "priority": 85,
  "conditions": {
    "categories": [
      "OST_PipeCurves",
      "OST_FlexPipeCurves",
      "OST_PipeAccessory",
      "OST_PipeFitting"
    ],
    "familyNamePatterns": [
      ".*CHW.*",
      ".*LTHW.*",
      ".*Chilled.*",
      ".*Heating.*",
      ".*Kälte.*",
      ".*Heizung.*"
    ],
    "viewTypes": ["FloorPlan", "CeilingPlan", "Section"]
  },
  "actions": {
    "preferredPositions": ["TopCenter", "Center", "BottomCenter"],
    "offsetDistance": 0.15,
    "addLeader": false,
    "leaderStyle": "None",
    "avoidCollisionWith": [
      "OST_PipeCurves",
      "OST_DuctCurves",
      "OST_Grids"
    ],
    "alignToGrid": false,
    "groupAlignment": "None"
  },
  "scoring": {
    "collisionPenalty": -80,
    "preferenceBonus": 60,
    "alignmentBonus": 10,
    "leaderLengthPenalty": 0,
    "nearEdgeBonus": 5
  },
  "tagFormat": {
    "pattern": "[SystemCode]-DN[Size]",
    "systemCodes": {
      "CHWF": {
        "name": "Kältevorlauf",
        "english": "Chilled Water Flow/Supply",
        "sizes_DN": [25, 32, 40, 50, 65, 80, 100, 125, 150, 200, 300, 400, 500]
      },
      "CHWR": {
        "name": "Kälterücklauf",
        "english": "Chilled Water Return",
        "sizes_DN": [25, 32, 40, 50, 65, 80, 100, 125, 150, 200, 300, 400, 500]
      },
      "LTHWF": {
        "name": "Heizungsvorlauf",
        "english": "Low Temp Hot Water Flow/Supply",
        "sizes_DN": [20, 25, 32, 40, 50, 65, 80, 100, 125, 200]
      },
      "LTHWR": {
        "name": "Heizungsrücklauf",
        "english": "Low Temp Hot Water Return",
        "sizes_DN": [20, 25, 32, 40, 50, 65, 80, 100, 125, 200]
      },
      "CONF": {
        "name": "Kaltwasser Vorlauf",
        "english": "Condenser Water Flow",
        "sizes_DN": [100, 150, 200, 300, 400, 500]
      },
      "DCF": {
        "name": "Kaltwasser Rücklauf",
        "english": "Condenser Water Return",
        "sizes_DN": [100, 150, 200, 300, 400, 500]
      }
    },
    "examples": [
      "CHWF-DN150",
      "CHWR-DN150",
      "LTHWF-DN80",
      "LTHWR-DN80",
      "CONF-DN500"
    ]
  },
  "elevationTagFormat": {
    "centerline": "RA = +[elevation] OKRFB",
    "invert": "RS = +[elevation] OKRFB",
    "notes": "RA=Rohrachse (centerline), RS=Rohrsohle (invert)"
  },
  "metadata": {
    "createdAt": "2026-02-13T15:00:00Z",
    "updatedAt": "2026-02-13T15:00:00Z",
    "author": "SmartTag",
    "source": "Munich Arena Heating/Cooling drawings (HZGA)",
    "confidence": 0.9,
    "sampleCount": 300
  },
  "_comments": {
    "patternNotes": [
      "System codes: CHW=Chilled Water, LTHW=Low Temp Hot Water, CON=Condenser",
      "Suffix: F=Flow/Vorlauf (Supply), R=Rücklauf (Return)",
      "Pipe tags placed along centerline without leaders",
      "Elevation tags use RA (centerline) or RS (invert)"
    ]
  }
}
