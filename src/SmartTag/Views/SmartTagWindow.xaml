<Window x:Class="SmartTag.SmartTagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartTag"
        xmlns:models="clr-namespace:SmartTag.Models"
        Title="Smart Tag" 
        Height="700" 
        Width="460"
        MinHeight="550"
        MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="False"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Link Button Style -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="text" 
                                       Text="{TemplateBinding Content}" 
                                       Foreground="{TemplateBinding Foreground}"
                                       TextDecorations="Underline"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="text" Property="Foreground" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Null to Visibility Converter -->
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        
        <!-- Bool to Visibility Converter -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- String (non-empty) to Visibility -->
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16" Background="#1976D2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Smart Tag" 
                               FontSize="22" 
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Auto-tag elements in your view" 
                               FontSize="12" 
                               Foreground="#BBDEFB"
                               Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Refresh Button -->
                <Button Grid.Column="1" 
                        Content="Refresh" 
                        Command="{Binding RefreshCategoriesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Foreground="White"
                        BorderBrush="White"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content with TabControl -->
        <TabControl Grid.Row="1" 
                    Margin="16,8,16,0"
                    Background="Transparent"
                    BorderThickness="0">
            
            <!-- TAB 1: Auto Tagging -->
            <TabItem Header="Auto Tag" Padding="16,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,16">
                    <StackPanel>
                <!-- Category Selection Section -->
                <TextBlock Text="SELECT CATEGORIES" 
                           FontSize="11" 
                           FontWeight="SemiBold"
                           Foreground="#757575"
                           Margin="0,0,0,8"/>

                <!-- Quick Selection Links -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="All" 
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource LinkButtonStyle}"/>
                    <TextBlock Text=" | " Foreground="#BDBDBD" VerticalAlignment="Center"/>
                    <Button Content="None" 
                            Command="{Binding SelectNoneCommand}"
                            Style="{StaticResource LinkButtonStyle}"/>
                    <TextBlock Text=" | " Foreground="#BDBDBD" VerticalAlignment="Center"/>
                    <Button Content="Untagged Only" 
                            Command="{Binding SelectUntaggedCommand}"
                            Style="{StaticResource LinkButtonStyle}"/>
                </StackPanel>

                <!-- Category List with Tag Type Selection -->
                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="6"
                        MaxHeight="280">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="0,4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Row 1: Checkbox + Category Name + Count -->
                                            <CheckBox Grid.Row="0" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" 
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                                                <Setter Property="Text">
                                                                    <Setter.Value>
                                                                        <MultiBinding StringFormat="({0}/{1})">
                                                                            <Binding Path="UntaggedCount"/>
                                                                            <Binding Path="ElementCount"/>
                                                                        </MultiBinding>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </CheckBox>
                                            
                                            <!-- Row 2: Tag Type Selector (shown when selected and has multiple types) -->
                                            <StackPanel Grid.Row="1" 
                                                        Orientation="Horizontal" 
                                                        Margin="24,4,0,0"
                                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Tag:" 
                                                           VerticalAlignment="Center"
                                                           Foreground="#757575"
                                                           FontSize="11"
                                                           Margin="0,0,6,0"/>
                                                <ComboBox ItemsSource="{Binding AvailableTagTypes}"
                                                          SelectedItem="{Binding SelectedTagType, Mode=TwoWay}"
                                                          DisplayMemberPath="DisplayName"
                                                          Width="200"
                                                          FontSize="11"
                                                          Padding="4,2"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Selection Summary -->
                <TextBlock Margin="0,8,0,0" Foreground="#757575" FontSize="12">
                    <Run Text="{Binding SelectedCategoryCount, Mode=OneWay}"/>
                    <Run Text=" categories selected, "/>
                    <Run Text="{Binding TotalElementCount, Mode=OneWay}"/>
                    <Run Text=" elements"/>
                </TextBlock>

                <!-- Settings Section -->
                <TextBlock Text="SETTINGS" 
                           FontSize="11" 
                           FontWeight="SemiBold"
                           Foreground="#757575"
                           Margin="0,24,0,8"/>

                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="6"
                        Padding="16">
                    <StackPanel>
                        <!-- Tag Position -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Position:" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding AvailablePositions}"
                                      SelectedItem="{Binding SelectedPosition}"
                                      Width="150"
                                      HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- Options -->
                        <CheckBox Content="Skip already tagged elements" 
                                  IsChecked="{Binding SkipTaggedElements}"/>
                        <CheckBox Content="Add leader lines" 
                                  IsChecked="{Binding AddLeaders}"/>
                        <CheckBox Content="Align tags in rows" 
                                  IsChecked="{Binding AlignTags}"/>
                    </StackPanel>
                </Border>

                <!-- Preview Section -->
                        <Border Background="#E8F5E9" 
                                BorderBrush="#C8E6C9" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Preview:" 
                                           FontWeight="SemiBold"
                                           Foreground="#2E7D32"
                                           VerticalAlignment="Center"/>
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Run Text="{Binding PreviewTagCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text=" tags will be created"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Preview/Confirm/Undo Buttons -->
                        <Border Background="#FFF8E1" 
                                BorderBrush="#FFE082" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,16,0,0"
                                Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#F57C00" Margin="0,0,0,8">
                                    <Run Text="Preview Mode: "/>
                                    <Run Text="{Binding PreviewCreatedCount, Mode=OneWay}"/>
                                    <Run Text=" tags created"/>
                                </TextBlock>
                                <TextBlock Text="Review the tags in Revit, then Confirm to keep or Undo to remove." 
                                           TextWrapping="Wrap"
                                           Foreground="#EF6C00"
                                           FontSize="11"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0"
                                            Content="Confirm Tags" 
                                            Command="{Binding ConfirmPreviewCommand}"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            Padding="12,8"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#43A047"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    
                                    <Button Grid.Column="2"
                                            Content="Undo Preview" 
                                            Command="{Binding UndoPreviewCommand}"
                                            Background="#F44336"
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            Padding="12,8"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#E53935"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Main Action Buttons (hidden during preview mode) -->
                        <StackPanel Margin="0,20,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPreviewMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            
                            <!-- Preview Button (recommended) -->
                            <Button Content="Preview Tags" 
                                    Command="{Binding CreatePreviewCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    FontSize="14"
                                    Height="44"
                                    ToolTip="Create tags as preview - you can undo if not satisfied"/>
                            
                            <!-- Direct Create Button (smaller, secondary) -->
                            <Button Content="Create Tags Directly (No Preview)" 
                                    Command="{Binding ExecuteAutoTagCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    FontSize="12"
                                    Height="32"
                                    Margin="0,8,0,0"
                                    ToolTip="Create tags immediately without preview"/>
                            <!-- Export training data: export current view's tags to JSON for updating rules/patterns -->
                            <Button Content="Export training data from view"
                                    Command="{Binding ExportTrainingDataCommand}"
                                    Style="{StaticResource LinkButtonStyle}"
                                    FontSize="11"
                                    Margin="0,16,0,0"
                                    ToolTip="Export tagged elements from current view to JSON. Put file in repo and ask assistant to update rules/patterns."/>
                            <TextBlock Text="{Binding ExportTrainingDataMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="#2E7D32"
                                       FontSize="10"
                                       Margin="0,4,0,0"
                                       Visibility="{Binding ExportTrainingDataMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Auto Dimension -->
            <TabItem Header="Auto Dimension" Padding="16,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,16">
                    <StackPanel>
                        <!-- Info Banner -->
                        <Border Background="#E3F2FD" 
                                BorderBrush="#BBDEFB" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,16">
                            <TextBlock Text="Creates chain dimensions from grids/walls to opening centers." 
                                       TextWrapping="Wrap"
                                       Foreground="#1565C0"
                                       FontSize="12"/>
                        </Border>

                        <!-- Dimension Mode -->
                        <TextBlock Text="DIMENSION MODE" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="#757575"
                                   Margin="0,0,0,8"/>

                        <Border Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Mode:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding AvailableDimensionModes}"
                                              SelectedItem="{Binding SelectedDimensionMode}"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Direction:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding AvailableDimensionDirections}"
                                              SelectedItem="{Binding SelectedDimensionDirection}"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Dim Type:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding DimensionTypes}"
                                              SelectedItem="{Binding SelectedDimensionType}"
                                              DisplayMemberPath="Name"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Reference Options -->
                        <TextBlock Text="REFERENCES" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="#757575"
                                   Margin="0,0,0,8"/>

                        <Border Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Content="Use Grids as reference" 
                                          IsChecked="{Binding UseGridsForDimension}"
                                          Margin="0,0,0,8"/>
                                <CheckBox Content="Use Walls as reference" 
                                          IsChecked="{Binding UseWallsForDimension}"/>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Margin="0,8,0,0">
                            <Button Content="Dimension All Openings in View" 
                                    Command="{Binding ExecuteAutoDimensionCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    FontSize="14"
                                    Height="44"/>
                            
                            <Button Content="Dimension Selected Only" 
                                    Command="{Binding DimensionSelectionCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    FontSize="13"
                                    Height="38"
                                    Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Result Summary -->
                        <Border Background="#FFF3E0" 
                                BorderBrush="#FFE0B2" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,16,0,0"
                                Visibility="{Binding LastDimensionResult, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,4">
                                    <Run Text="Last Result: "/>
                                    <Run Text="{Binding LastDimensionResult.DimensionsCreated, Mode=OneWay}"/>
                                    <Run Text=" dimensions"/>
                                </TextBlock>
                                <TextBlock Foreground="#EF6C00" FontSize="11">
                                    <Run Text="Groups: "/>
                                    <Run Text="{Binding LastDimensionResult.GroupsProcessed, Mode=OneWay}"/>
                                    <Run Text=" | Openings: "/>
                                    <Run Text="{Binding LastDimensionResult.OpeningsProcessed, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Status Icon -->
                <TextBlock Grid.Column="0" FontSize="14"
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           Foreground="#757575">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Text" Value=""/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="Text" Value=""/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <!-- Status Message -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#757575"/>
                
                <!-- Loading Indicator -->
                <ProgressBar Grid.Column="2"
                             Width="18" Height="18"
                             IsIndeterminate="True"
                             Margin="10,0,0,0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </Grid>
        </Border>
    </Grid>
</Window>
