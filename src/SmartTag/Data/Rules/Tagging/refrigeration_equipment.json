{
  "$schema": "../Schema/TaggingRule.schema.json",
  "id": "refrigeration_equipment",
  "name": "Refrigeration Equipment - KLT Connected (Fan Coils, Ceiling Panels, Valves)",
  "description": "Tagging rules for equipment connected to KLT (Kältetechnik) cooling system - fan coils, dual-mode ceiling panels on cooling circuit, and valves",
  "version": "2.0.0",
  "enabled": true,
  "priority": 83,
  "systemConnection": "KLT",
  "systemConnectionNote": "Use this rule for equipment connected to KLT-* piping systems (KLT-IT, KLT-HKS, KLT-GLK, KLT-UFK)",
  "conditions": {
    "categories": [
      "OST_MechanicalEquipment",
      "OST_PipeAccessory",
      "OST_PipeFitting",
      "OST_GenericModel"
    ],
    "familyNamePatterns": [
      ".*Ventilatorkonvektor.*",
      ".*FanCoil.*",
      ".*FCU.*"
    ],
    "systemNamePatterns": [".*KLT.*"],
    "viewTypes": ["FloorPlan", "CeilingPlan", "ReflectedCeilingPlan"]
  },
  "metadata": {
    "author": "SmartTag AI Training",
    "category": "Cooling/Refrigeration",
    "discipline": "KLT (Kältetechnik)",
    "sources": ["MunichRE KLT drawings - 24 files"],
    "sampleCount": 500,
    "updatedAt": "2026-02-13"
  },
  "equipmentTypes": [
    {
      "type": "Fan Coil Unit",
      "german": "Ventilatorkonvektor",
      "english": "Fan Coil Unit (FCU)",
      "tagFormat": {
        "pattern": "Ventilatorkonvektor\nL[L]xW[W]xH[H]\nKühlleistung: [Value] W",
        "multiLine": true,
        "components": {
          "L": "Length in mm",
          "W": "Width in mm",
          "H": "Height in mm",
          "Kühlleistung": "Cooling capacity in Watts"
        }
      },
      "standardDimensions": "L1725xW519xH223",
      "coolingCapacities": [136, 469, 1000, 5000],
      "examples": [
        "Ventilatorkonvektor\nL1725xW519xH223\nKühlleistung: 5000 W",
        "Ventilatorkonvektor\nL1725xW519xH223\nKühlleistung: 469 W"
      ]
    },
    {
      "type": "Heating/Cooling Ceiling Panel",
      "german": "HeizKühlsegel Decke",
      "english": "Heating/Cooling Ceiling Sail",
      "tagFormat": {
        "pattern": "HeizKühlsegel Decke\n[Dimensions]\nHeizleistung: [Heat] W\nKühlleistung: [Cool] W",
        "multiLine": true,
        "components": {
          "Dimensions": "LxW dimensions",
          "Heizleistung": "Heating capacity in Watts",
          "Kühlleistung": "Cooling capacity in Watts"
        }
      },
      "standardDimensions": "1500x650",
      "typicalCapacities": {
        "heating": 2000,
        "cooling": 5600
      },
      "examples": [
        "HeizKühlsegel Decke\n1500x650\nHeizleistung: 2000 W\nKühlleistung: 5600 W"
      ]
    }
  ],
