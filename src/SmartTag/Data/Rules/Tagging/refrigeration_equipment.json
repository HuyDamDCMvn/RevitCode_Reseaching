  "dualModeEquipment": {
    "_comment": "HeizKühlsegel can be connected to either HZG or KLT - use KLT rule when primarily cooling",
    "heatingCoolingCeiling": {
      "pattern": "HeizKühlsegel Decke\n[Dimensions]\nHeizleistung: [Value] W\nKühlleistung: [Value] W",
      "note": "When connected to KLT-HKS system, tag via this rule",
      "connectedSystem": "KLT-HKS"
    }
  },
  "actions": {
    "preferredPositions": ["Center", "TopCenter", "Right"],
    "offsetDistance": 0.15,
    "addLeader": true,
    "leaderStyle": "Straight",
    "avoidCollisionWith": ["OST_MechanicalEquipment", "OST_Ceilings"]
  },
  "scoring": {
    "collisionPenalty": -55,
    "preferenceBonus": 45,
    "alignmentBonus": 15,
    "leaderLengthPenalty": -3
  },
  "rules": [
    {
      "condition": { "familyName": "contains", "value": "Fan Coil" },
      "tagSettings": { "pattern": "Ventilatorkonvektor\nL{Length}xW{Width}xH{Height}\nKühlleistung: {CoolingCapacity} W", "multiLine": true }
    },
    {
      "condition": { "familyName": "contains", "value": "Ceiling Panel", "systemName": "contains", "systemValue": "KLT" },
      "tagSettings": { "pattern": "HeizKühlsegel Decke\n{Dimensions}\nHeizleistung: {HeatingCapacity} W\nKühlleistung: {CoolingCapacity} W", "multiLine": true }
    },
    {
      "condition": { "familyName": "contains", "value": "Ball Valve" },
      "tagSettings": { "pattern": "DN{Size}\nKugelhahn Gewinde" }
    },
    {
      "condition": { "familyName": "contains", "value": "Pressure" },
      "tagSettings": { "pattern": "DN{Size}\nDruckregelventil Gewinde" }
    },
    {
      "condition": { "familyName": "contains", "value": "6-Way" },
      "tagSettings": { "pattern": "DN{Size}\n6WegeVentil Gewinde" }
    }
  ]
