{
  "$schema": "../Schema/TaggingRule.schema.json",
  "id": "sanitary_fixtures_german",
  "name": "Sanitary Fixtures & Equipment - German Standard",
  "description": "Tagging rules for plumbing fixtures and equipment using German naming (merged from TUV + MunichRE)",
  "version": "2.0.0",
  "enabled": true,
  "priority": 75,
  "conditions": {
    "categories": [
      "OST_PlumbingFixtures",
      "OST_PlumbingEquipment",
      "OST_Sprinklers",
      "OST_GenericModel"
    ],
    "familyNamePatterns": [
      ".*Drain.*",
      ".*WaterHeater.*",
      ".*Valve.*",
      ".*Station.*",
      ".*Rinne.*",
      ".*Bodenablauf.*",
      ".*WC.*",
      ".*Waschtisch.*",
      ".*Urinal.*"
    ],
    "viewTypes": ["FloorPlan", "CeilingPlan"]
  },
  "actions": {
    "preferredPositions": ["Right", "TopRight", "BottomRight", "Left"],
    "offsetDistance": 0.3,
    "addLeader": true,
    "leaderStyle": "Straight",
    "avoidCollisionWith": ["OST_PipeCurves", "OST_PlumbingFixtures", "OST_Walls"],
    "alignToGrid": false
  },
  "scoring": {
    "collisionPenalty": -100,
    "preferenceBonus": 50,
    "alignmentBonus": 15,
    "leaderLengthPenalty": -3,
    "nearEdgeBonus": 10
  },
  "metadata": {
    "author": "SmartTag AI Training",
    "category": "Sanitary/Plumbing",
    "discipline": "SAN (Sanitär)",
    "sources": ["Munich Arena TUV", "MunichRE Revitalization"],
    "sampleCount": 150,
    "updatedAt": "2026-02-13"
  },
  "fixtureTypes": [
    {
      "type": "WC Element",
      "german": "Duofix Element Für Wandhängende WC",
      "english": "Wall-hung WC Frame",
