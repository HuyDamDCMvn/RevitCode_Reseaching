        "german": "Frischwasserstation",
        "pattern": "Frischwasserstation Standard"
      }
    ],
    "channels": [
      {
        "id": "floor_channel",
        "german": "Bodenrinne",
        "pattern": "Bodenrinne [Width]x[Length]",
        "example": "Bodenrinne 200x1100"
      }
    ]
  },
  "rules": [
    {
      "condition": { "familyName": "contains", "value": "WC" },
      "tagSettings": { "pattern": "Duofix Element Für Wandhängende WC\nStandard" }
    },
    {
      "condition": { "familyName": "contains", "value": "Waschtisch" },
      "tagSettings": { "pattern": "Waschtisch\nStandard" }
    },
    {
      "condition": { "familyName": "contains", "value": "Urinal" },
      "tagSettings": { "pattern": "Urinal_Universell\nStandard" }
    },
    {
      "condition": { "familyName": "contains", "value": "Floor Drain" },
      "tagSettings": { "pattern": "DN{Size}\nBodenablaufe", "defaultSize": 80 }
    },
    {
      "condition": { "familyName": "contains", "value": "Bodenrinne" },
      "tagSettings": { "pattern": "Bodenrinne {Width}x{Length}" }
    },
    {
      "condition": { "familyName": "contains", "value": "WaterHeater" },
      "tagSettings": { "pattern": "Durchlauferhitzer_{Subtype} Standard" }
    },
    {
      "condition": { "familyName": "contains", "value": "Station" },
      "tagSettings": { "pattern": "Frischwasserstation Standard" }
    }
  ]
