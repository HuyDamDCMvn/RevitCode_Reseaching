<Window x:Class="RevitChat.UI.RevitChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RevitChat.Models"
        Title="Revit AI Chat" 
        Height="640" Width="420"
        MinHeight="480" MinWidth="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="False"
        Background="#F5F5F5"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Chat bubble - User -->
        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="48,4,12,4" HorizontalAlignment="Right">
                <Border Background="#1976D2" CornerRadius="12,12,2,12" Padding="12,8" MaxWidth="320">
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="White" FontSize="13"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Chat bubble - Assistant -->
        <DataTemplate x:Key="AssistantMessageTemplate" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="12,4,48,4" HorizontalAlignment="Left">
                <StackPanel>
                    <Border Background="White" CornerRadius="12,12,12,2" Padding="12,8" MaxWidth="320"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#212121" FontSize="13"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="4,2,0,0"
                                Visibility="{Binding ShowFeedbackButtons, Converter={StaticResource BoolToVis}}">
                        <Button Style="{DynamicResource IconButtonStyle}" Padding="3" ToolTip="Good response"
                                Command="{Binding DataContext.ThumbsUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="&#xE8E1;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#9E9E9E"/>
                        </Button>
                        <Button Style="{DynamicResource IconButtonStyle}" Padding="3" Margin="2,0,0,0" ToolTip="Wrong response"
                                Command="{Binding DataContext.ThumbsDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="&#xE8E0;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#9E9E9E"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Chat bubble - Tool progress -->
        <DataTemplate x:Key="ToolMessageTemplate" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="12,2,48,2" HorizontalAlignment="Left">
                <Border Background="#FFF8E1" CornerRadius="8" Padding="8,4" MaxWidth="320"
                        BorderBrush="#FFE082" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar IsIndeterminate="True" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Content}" FontSize="11" Foreground="#F57F17" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Template selector via style triggers -->
        <Style x:Key="MessageItemStyle" TargetType="ContentPresenter">
            <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="{x:Static models:ChatRole.User}">
                    <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsToolCall}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource ToolMessageTemplate}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern button style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send button -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1976D2" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Revit AI Chat" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}" 
                        Command="{Binding ClearChatCommand}" ToolTip="Clear chat" Margin="4,0">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White"/>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" 
                        Command="{Binding ToggleSettingsCommand}" ToolTip="Settings">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- Settings panel (collapsible) -->
        <Border Grid.Row="1" Background="#FAFAFA" Padding="14" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="10">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <TextBlock Text="OpenAI API Key" FontSize="12" Foreground="#616161" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ApiKeyBox" 
                             FontSize="12" Padding="8,6" Margin="0,0,0,10"
                             PasswordChanged="ApiKeyBox_PasswordChanged"/>

                <TextBlock Text="Model" FontSize="12" Foreground="#616161" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AvailableModels}" 
                          SelectedItem="{Binding SelectedModel}" 
                          FontSize="12" Padding="6,4" Margin="0,0,0,14"/>

                <Button Content="Save" Style="{StaticResource SendButtonStyle}" 
                        HorizontalAlignment="Left" Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>
        </Border>

        <!-- Chat messages -->
        <ListBox Grid.Row="1" x:Name="ChatList"
                 ItemsSource="{Binding Messages}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 HorizontalContentAlignment="Stretch"
                 Padding="0,8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ContentPresenter Content="{Binding}" Style="{StaticResource MessageItemStyle}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Input area -->
        <Border Grid.Row="2" Background="White" Padding="10,8" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="InputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="10,8"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         BorderBrush="#E0E0E0" BorderThickness="1"
                         KeyDown="InputBox_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Send button: visible when NOT busy -->
                <Button x:Name="SendBtn" Grid.Column="1" Margin="6,0,0,0"
                        Command="{Binding SendCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SendButtonStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>

                <!-- Cancel button: visible when busy -->
                <Button Grid.Column="1" Margin="6,0,0,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource SendButtonStyle}" Background="#E53935"
                        Command="{Binding CancelCommand}" ToolTip="Cancel">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#FAFAFA" Padding="12,6"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                           FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <ProgressBar Grid.Column="1" Width="16" Height="16" IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
