<Window x:Class="CommonFeature.Views.BoundaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Show Boundary" 
        Height="520" 
        Width="380"
        MinHeight="480"
        MinWidth="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="True"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Toggle Button Style -->
        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Radio Button Style -->
        <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Foreground" Value="#424242"/>
        </Style>

        <!-- Slider Style -->
        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" Background="#FF9800">
            <StackPanel>
                <TextBlock Text="Show Boundary" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock x:Name="SelectionText"
                           Text="No elements selected" 
                           FontSize="11" 
                           Foreground="#FFE0B2"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,12">
            <StackPanel>
                <!-- Selection Section -->
                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Selection" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Button x:Name="PickElementsButton"
                                Content="Pick Elements"
                                Padding="12,8"
                                Background="#2196F3"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="PickElements_Click"/>
                        <TextBlock x:Name="ElementCountText"
                                   Text="0 element(s) selected"
                                   FontSize="11"
                                   Foreground="#757575"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Bounding Box Section -->
                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bounding Box" FontWeight="SemiBold"/>
                            <ToggleButton x:Name="ShowBoundingBoxToggle"
                                          Grid.Column="1"
                                          Content="Show"
                                          Style="{StaticResource ToggleButtonStyle}"
                                          Checked="BoundingBoxToggle_Changed"
                                          Unchecked="BoundingBoxToggle_Changed"/>
                        </Grid>
                        
                        <StackPanel Margin="0,10,0,0">
                            <RadioButton x:Name="OriginAxisRadio"
                                         Content="Origin (World Axis)"
                                         GroupName="BoundingBoxMode"
                                         IsChecked="True"
                                         Style="{StaticResource RadioButtonStyle}"
                                         Checked="BoundingBoxMode_Changed"/>
                            <RadioButton x:Name="RotatedAxisRadio"
                                         Content="Rotated (Element Axis)"
                                         GroupName="BoundingBoxMode"
                                         Style="{StaticResource RadioButtonStyle}"
                                         Checked="BoundingBoxMode_Changed"/>
                        </StackPanel>

                        <!-- Bounding Box Color -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Color:" VerticalAlignment="Center"/>
                            <Border x:Name="BoundingBoxColorPreview"
                                    Grid.Column="1"
                                    Background="#2196F3"
                                    Width="60"
                                    Height="24"
                                    CornerRadius="2"
                                    Margin="8,0"
                                    BorderBrush="#BDBDBD"
                                    BorderThickness="1"/>
                            <Button Grid.Column="2"
                                    Content="Change"
                                    Padding="8,4"
                                    FontSize="11"
                                    Click="ChangeBoundingBoxColor_Click"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Line Thickness -->
                        <StackPanel Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Line Thickness:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LineThicknessValue" 
                                           Grid.Column="1" 
                                           Text="2" 
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <Slider x:Name="LineThicknessSlider"
                                    Minimum="1"
                                    Maximum="10"
                                    Value="2"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource SliderStyle}"
                                    ValueChanged="LineThickness_ValueChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Points Section -->
                <Border Background="White" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Points Display" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        
                        <!-- Min Point -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="ShowMinPointToggle"
                                          Content="Min"
                                          Width="50"
                                          Style="{StaticResource ToggleButtonStyle}"
                                          Checked="PointToggle_Changed"
                                          Unchecked="PointToggle_Changed"/>
                            <TextBlock Grid.Column="1" Text="Min Point" 
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Border x:Name="MinPointColorPreview"
                                    Grid.Column="2"
                                    Background="#F44336"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="2"
                                    BorderBrush="#BDBDBD"
                                    BorderThickness="1"
                                    Margin="0,0,4,0"/>
                            <Button Grid.Column="3"
                                    Content="..."
                                    Width="28"
                                    Padding="0"
                                    FontSize="11"
                                    Tag="MinPoint"
                                    Click="ChangePointColor_Click"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Max Point -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="ShowMaxPointToggle"
                                          Content="Max"
                                          Width="50"
                                          Style="{StaticResource ToggleButtonStyle}"
                                          Checked="PointToggle_Changed"
                                          Unchecked="PointToggle_Changed"/>
                            <TextBlock Grid.Column="1" Text="Max Point" 
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Border x:Name="MaxPointColorPreview"
                                    Grid.Column="2"
                                    Background="#4CAF50"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="2"
                                    BorderBrush="#BDBDBD"
                                    BorderThickness="1"
                                    Margin="0,0,4,0"/>
                            <Button Grid.Column="3"
                                    Content="..."
                                    Width="28"
                                    Padding="0"
                                    FontSize="11"
                                    Tag="MaxPoint"
                                    Click="ChangePointColor_Click"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Centroid Point -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="ShowCentroidToggle"
                                          Content="Cen"
                                          Width="50"
                                          Style="{StaticResource ToggleButtonStyle}"
                                          Checked="PointToggle_Changed"
                                          Unchecked="PointToggle_Changed"/>
                            <TextBlock Grid.Column="1" Text="Centroid" 
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <Border x:Name="CentroidColorPreview"
                                    Grid.Column="2"
                                    Background="#FFC107"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="2"
                                    BorderBrush="#BDBDBD"
                                    BorderThickness="1"
                                    Margin="0,0,4,0"/>
                            <Button Grid.Column="3"
                                    Content="..."
                                    Width="28"
                                    Padding="0"
                                    FontSize="11"
                                    Tag="Centroid"
                                    Click="ChangePointColor_Click"
                                    Cursor="Hand"/>
                        </Grid>

                        <!-- Sphere Diameter -->
                        <StackPanel Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sphere Diameter (mm):" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SphereDiameterValue" 
                                           Grid.Column="1" 
                                           Text="100" 
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <Slider x:Name="SphereDiameterSlider"
                                    Minimum="20"
                                    Maximum="500"
                                    Value="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Style="{StaticResource SliderStyle}"
                                    ValueChanged="SphereDiameter_ValueChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Info Panel -->
                <Border Background="#FFF3E0" 
                        BorderBrush="#FFB74D" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="12">
                    <TextBlock Text="Preview graphics will automatically clear when this window is closed."
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#E65100"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" 
                Padding="16,10" 
                Background="#F5F5F5" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="ClearPreviewButton"
                        Grid.Column="0"
                        Content="Clear Preview"
                        Padding="12,6"
                        Click="ClearPreview_Click"/>

                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Content="Close"
                        Padding="12,6"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
