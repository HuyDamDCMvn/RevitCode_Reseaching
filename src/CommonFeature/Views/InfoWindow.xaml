<Window x:Class="CommonFeature.Views.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Element Information" 
        Height="600" 
        Width="1100"
        MinHeight="450"
        MinWidth="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16" Background="#3F51B5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Element Information" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock x:Name="CountText"
                               Text="0 elements" 
                               FontSize="12" 
                               Foreground="#BBDEFB"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AddParamButton"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Add parameter columns from selected elements"
                            Click="AddParamButton_Click"
                            Cursor="Hand">
                        <TextBlock Text="Add Param"/>
                    </Button>
                    <Button x:Name="UpdateValueButton"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Background="#FF9800"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Update modified values to Revit model"
                            Click="UpdateValueButton_Click"
                            Cursor="Hand"
                            IsEnabled="False">
                        <TextBlock Text="Update Value"/>
                    </Button>
                    <Button x:Name="ClearFilterButton"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Background="#5C6BC0"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Clear all filters"
                            Click="ClearFilterButton_Click"
                            Cursor="Hand">
                        <TextBlock Text="Clear Filters"/>
                    </Button>
                    <Button x:Name="ExportButton"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Background="#5C6BC0"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Export to CSV"
                            Click="ExportButton_Click"
                            Cursor="Hand">
                        <TextBlock Text="Export CSV"/>
                    </Button>
                    <Button x:Name="RefreshButton"
                            Padding="12,8"
                            Background="#5C6BC0"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Refresh data"
                            Click="RefreshButton_Click"
                            Cursor="Hand">
                        <TextBlock Text="Refresh"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid with horizontal scroll -->
        <DataGrid x:Name="InfoDataGrid"
                  Grid.Row="1"
                  Margin="16,8,16,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0"
                  Background="White"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True"
                  CellEditEnding="InfoDataGrid_CellEditEnding"
                  BeginningEdit="InfoDataGrid_BeginningEdit"
                  MouseRightButtonUp="InfoDataGrid_MouseRightButtonUp">
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="#424242"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            
            <DataGrid.Columns>
                <!-- ID Column -->
                <DataGridTextColumn Binding="{Binding Id}" Width="80" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="Id" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                
                <!-- Family Name Column -->
                <DataGridTextColumn Binding="{Binding FamilyName}" Width="*" MinWidth="150" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Family Name" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="FamilyName" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                
                <!-- Family Type Column -->
                <DataGridTextColumn Binding="{Binding FamilyType}" Width="*" MinWidth="150" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Family Type" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="FamilyType" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                
                <!-- Category Column -->
                <DataGridTextColumn Binding="{Binding Category}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Category" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="Category" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                
                <!-- Workset Column -->
                <DataGridTextColumn Binding="{Binding Workset}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Workset" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="Workset" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                
                <!-- Created By Column -->
                <DataGridTextColumn Binding="{Binding CreatedBy}" Width="110" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Created By" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="CreatedBy" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                
                <!-- Edited By Column -->
                <DataGridTextColumn Binding="{Binding EditedBy}" Width="110" IsReadOnly="True">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Edited By" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button Grid.Column="1" Tag="EditedBy" Padding="4" Margin="0,0,2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Filter" Click="FilterButton_Click" Cursor="Hand">
                                    <TextBlock Text="▼" FontSize="10" Foreground="#757575"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Parameter Selection Popup -->
        <Popup x:Name="ParamPopup" 
               StaysOpen="False" 
               Placement="Bottom"
               AllowsTransparency="True">
            <Border Background="White"
                    BorderBrush="#BDBDBD"
                    BorderThickness="1"
                    Padding="12"
                    MinWidth="350"
                    MaxHeight="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Title -->
                    <TextBlock Grid.Row="0" Text="Select Parameters to Add" 
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                    
                    <!-- Search Box -->
                    <TextBox x:Name="ParamSearchBox"
                             Grid.Row="1"
                             Margin="0,0,0,8"
                             Padding="8,6"
                             FontSize="12"
                             BorderBrush="#BDBDBD"
                             BorderThickness="1"
                             TextChanged="ParamSearchBox_TextChanged"/>
                    
                    <!-- Select All / Clear All -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Select All" FontSize="11" Padding="10,5" Margin="0,0,8,0"
                                Background="#E8E8E8" BorderThickness="0" Cursor="Hand"
                                Click="ParamSelectAllButton_Click"/>
                        <Button Content="Clear All" FontSize="11" Padding="10,5"
                                Background="#E8E8E8" BorderThickness="0" Cursor="Hand"
                                Click="ParamClearAllButton_Click"/>
                    </StackPanel>
                    
                    <!-- Parameter CheckBox List -->
                    <ScrollViewer Grid.Row="3" MaxHeight="280" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ParamItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,3">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Width="200"/>
                                            <TextBlock Text="{Binding TypeLabel}" Foreground="#757575" FontSize="11"
                                                       FontStyle="Italic" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Add Columns Button -->
                    <Button Grid.Row="4" Content="Add Selected Columns" Margin="0,10,0,0" Padding="16,8"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="AddParamColumnsButton_Click"/>
                </Grid>
            </Border>
        </Popup>

        <!-- Filter Popup -->
        <Popup x:Name="FilterPopup" 
               StaysOpen="False" 
               Placement="Bottom"
               AllowsTransparency="True">
            <Border Background="White"
                    BorderBrush="#BDBDBD"
                    BorderThickness="1"
                    Padding="12"
                    MinWidth="200"
                    MaxHeight="350">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Search Box -->
                    <TextBox x:Name="PopupSearchBox"
                             Grid.Row="0"
                             Margin="0,0,0,8"
                             Padding="8,6"
                             FontSize="12"
                             BorderBrush="#BDBDBD"
                             BorderThickness="1"
                             TextChanged="PopupSearchBox_TextChanged"/>
                    
                    <!-- Select All / Clear All -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Select All" FontSize="11" Padding="10,5" Margin="0,0,8,0"
                                Background="#E8E8E8" BorderThickness="0" Cursor="Hand"
                                Click="SelectAllButton_Click"/>
                        <Button Content="Clear All" FontSize="11" Padding="10,5"
                                Background="#E8E8E8" BorderThickness="0" Cursor="Hand"
                                Click="ClearAllButton_Click"/>
                    </StackPanel>
                    
                    <!-- CheckBox List -->
                    <ScrollViewer Grid.Row="2" MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FilterItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Value}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Apply Button -->
                    <Button Grid.Row="3" Content="Apply Filter" Margin="0,10,0,0" Padding="16,8"
                            Background="#3F51B5" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="ApplyFilterButton_Click"/>
                </Grid>
            </Border>
        </Popup>

        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                           x:Name="StatusText"
                           Text="Ready" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="#757575"/>
                
                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Content="Close"
                        Padding="20,8"
                        Background="#3F51B5"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
