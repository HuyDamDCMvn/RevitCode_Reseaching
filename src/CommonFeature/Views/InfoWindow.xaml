<Window x:Class="CommonFeature.Views.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Element Information" 
        Height="600" 
        Width="1100"
        MinHeight="450"
        MinWidth="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16" Background="#3F51B5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Element Information" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock x:Name="CountText"
                               Text="0 elements" 
                               FontSize="12" 
                               Foreground="#BBDEFB"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ExportButton"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Background="#5C6BC0"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Export to CSV"
                            Click="ExportButton_Click"
                            Cursor="Hand">
                        <TextBlock Text="Export CSV"/>
                    </Button>
                    <Button x:Name="RefreshButton"
                            Padding="12,8"
                            Background="#5C6BC0"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip="Refresh data"
                            Click="RefreshButton_Click"
                            Cursor="Hand">
                        <TextBlock Text="Refresh"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid - Simple columns without filters -->
        <DataGrid x:Name="InfoDataGrid"
                  Grid.Row="1"
                  Margin="16,8,16,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0"
                  Background="White"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="#424242"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="8,10"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Family Name" Binding="{Binding FamilyName}" Width="*" MinWidth="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Family Type" Binding="{Binding FamilyType}" Width="*" MinWidth="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Workset" Binding="{Binding Workset}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Created By" Binding="{Binding CreatedBy}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Edited By" Binding="{Binding EditedBy}" Width="110" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                           x:Name="StatusText"
                           Text="Ready" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="#757575"/>
                
                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Content="Close"
                        Padding="20,8"
                        Background="#3F51B5"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
