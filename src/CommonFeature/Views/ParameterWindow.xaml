<Window x:Class="CommonFeature.Views.ParameterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CommonFeature.Views"
        Title="Parameter Manager" 
        Height="700" 
        Width="1200"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="True"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Bool to Visibility Converter -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <!-- Tab Style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#3F51B5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#3F51B5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8EAF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#303F9F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#5C6BC0"/>
        </Style>

        <!-- Success Button Style -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#4CAF50"/>
        </Style>

        <!-- Warning Button Style -->
        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FF9800"/>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#F44336"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3F51B5" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Parameter Manager" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="HeaderSubtitle" Text="Select elements and load parameters" 
                               FontSize="12" Foreground="#BBDEFB" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" Content="🔄 Refresh" 
                            Style="{StaticResource SecondaryButtonStyle}" Click="RefreshButton_Click"/>
                    <Button x:Name="LoadFromSelectionButton" Content="📋 Load Selection" 
                            Style="{StaticResource SuccessButtonStyle}" Click="LoadFromSelectionButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <RadioButton x:Name="TabBrowse" Content="📂 Browse" 
                             Style="{StaticResource TabButtonStyle}" IsChecked="True"
                             Checked="Tab_Checked"/>
                <RadioButton x:Name="TabEdit" Content="✏️ Edit" 
                             Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked"/>
                <RadioButton x:Name="TabTransfer" Content="🔄 Transfer" 
                             Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked"/>
                <RadioButton x:Name="TabCompare" Content="⚖️ Compare" 
                             Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked"/>
                <RadioButton x:Name="TabValidate" Content="✅ Validate" 
                             Style="{StaticResource TabButtonStyle}"
                             Checked="Tab_Checked"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="16,12">
            <!-- Tab 1: Browse -->
            <Grid x:Name="BrowsePanel" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Parameter Tree -->
                <Border Grid.Column="0" Background="White" CornerRadius="4" Margin="0,0,8,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Parameters" FontWeight="SemiBold" 
                                   Margin="12,12,12,8" FontSize="14"/>

                        <TextBox x:Name="ParamSearchBox" Grid.Row="1" Margin="12,0,12,8" 
                                 Padding="8,6" BorderBrush="#BDBDBD"
                                 TextChanged="ParamSearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="🔍 Search parameters..." 
                                                                       Foreground="#9E9E9E" Margin="8,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TreeView x:Name="ParameterTreeView" Grid.Row="2" BorderThickness="0"
                                  Margin="0,0,0,8" SelectedItemChanged="ParameterTreeView_SelectedItemChanged">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Parameters}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayHeader}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                                          Margin="0,0,4,0"
                                                          Checked="ParamCheckBox_Changed"
                                                          Unchecked="ParamCheckBox_Changed"/>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text="{Binding TypeLabel}" Foreground="#9E9E9E" 
                                                           FontSize="11" Margin="4,0,0,0"/>
                                                <TextBlock Text=" 🔒" Foreground="#F44336" FontSize="10"
                                                           Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVisConverter}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <!-- Right: Data Grid -->
                <Border Grid.Column="1" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8">
                            <Button x:Name="AddColumnsButton" Content="➕ Add Columns" 
                                    Style="{StaticResource SuccessButtonStyle}" Click="AddColumnsButton_Click"/>
                            <Button x:Name="ClearColumnsButton" Content="🗑️ Clear Columns" 
                                    Style="{StaticResource SecondaryButtonStyle}" Click="ClearColumnsButton_Click"/>
                            <Button x:Name="ExportCsvButton" Content="📥 Export CSV" 
                                    Style="{StaticResource SecondaryButtonStyle}" Click="ExportCsvButton_Click"/>
                            <Button x:Name="CopyValueButton" Content="📋 Copy" 
                                    Style="{StaticResource SecondaryButtonStyle}" Click="CopyValueButton_Click"/>
                        </StackPanel>

                        <DataGrid x:Name="MainDataGrid" Grid.Row="1" Margin="8,0,8,8"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  GridLinesVisibility="Horizontal"
                                  IsReadOnly="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ElementId}" Width="80"/>
                                <DataGridTextColumn Header="Family" Binding="{Binding FamilyName}" Width="150"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="150"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Tab 2: Edit -->
            <Grid x:Name="EditPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Edit Toolbar -->
                <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="12" Margin="0,0,0,8"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Parameter:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="EditParamCombo" Grid.Column="1" Padding="8,6"
                                  SelectionChanged="EditParamCombo_SelectionChanged"/>

                        <TextBlock Grid.Column="2" Text="Formula:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TextBox x:Name="FormulaTextBox" Grid.Column="3" Padding="8,6"
                                 ToolTip="Enter formula: +10, *1.5, prefix_, _suffix, {UPPER}, {LOWER}, etc."/>

                        <Button Grid.Column="5" Content="▶️ Apply Formula" 
                                Style="{StaticResource WarningButtonStyle}" 
                                Click="ApplyFormulaButton_Click"/>
                    </Grid>
                </Border>

                <!-- Edit Data Grid -->
                <Border Grid.Row="1" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <DataGrid x:Name="EditDataGrid" Margin="8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              GridLinesVisibility="Horizontal"
                              IsReadOnly="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              CellEditEnding="EditDataGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ElementId}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Family" Binding="{Binding FamilyName}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="150" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Edit Actions -->
                <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="12" Margin="0,8,0,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="EditModifiedCount" Text="0 modified" 
                                   VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#757575"/>
                        <Button x:Name="UndoButton" Content="↩️ Undo" 
                                Style="{StaticResource SecondaryButtonStyle}" Click="UndoButton_Click"/>
                        <Button x:Name="ApplyChangesButton" Content="💾 Apply Changes" 
                                Style="{StaticResource SuccessButtonStyle}" Click="ApplyChangesButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tab 3: Transfer -->
            <Grid x:Name="TransferPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Transfer Options -->
                <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Transfer Mode" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        
                        <RadioButton x:Name="TransferModeMap" Content="Map Parameters (Source → Target)" 
                                     IsChecked="True" Margin="0,0,0,8" GroupName="TransferMode"
                                     Checked="TransferMode_Changed"/>
                        <Grid Margin="24,0,0,12" x:Name="MapOptionsPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="From:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="MapSourceCombo" Grid.Column="1" Padding="8,6"/>
                            <TextBlock Grid.Column="2" Text="→ To:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                            <ComboBox x:Name="MapTargetCombo" Grid.Column="3" Padding="8,6"/>
                            <Button Grid.Column="4" Content="🔄 Map Now" Margin="16,0,0,0"
                                    Style="{StaticResource WarningButtonStyle}" 
                                    HorizontalAlignment="Left" Click="MapParametersButton_Click"/>
                        </Grid>

                        <RadioButton x:Name="TransferModeElement" 
                                     Content="Transfer Between Elements (Copy from source element)" 
                                     Margin="0,0,0,8" GroupName="TransferMode"
                                     Checked="TransferMode_Changed"/>
                        <Grid Margin="24,0,0,12" x:Name="ElementTransferPanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Source Element ID:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="SourceElementIdTextBox" Grid.Column="1" Padding="8,6"/>
                            <Button Grid.Column="2" Content="📋 Transfer" Margin="16,0,0,0"
                                    Style="{StaticResource WarningButtonStyle}" Click="TransferElementButton_Click"/>
                        </Grid>

                        <Separator Margin="0,8"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="📥 Import CSV" Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="ImportCsvButton_Click"/>
                            <Button Content="📤 Export CSV" Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="ExportCsvButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Transfer Preview/Log -->
                <Border Grid.Row="1" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Transfer Log" FontWeight="SemiBold" Margin="12,12,12,8"/>
                        <ListBox x:Name="TransferLogList" Grid.Row="1" Margin="8,0,8,8" BorderThickness="0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Tab 4: Compare -->
            <Grid x:Name="ComparePanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Compare Options -->
                <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="16" Margin="0,0,0,8"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Comparison Mode" 
                                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="CompareModeTwo" Content="Compare 2 Elements" 
                                         IsChecked="True" GroupName="CompareMode" Margin="0,0,16,0"
                                         Checked="CompareMode_Changed"/>
                            <RadioButton x:Name="CompareModeEmpty" Content="Find Empty Values" 
                                         GroupName="CompareMode" Margin="0,0,16,0"
                                         Checked="CompareMode_Changed"/>
                            <RadioButton x:Name="CompareModeDuplicate" Content="Find Duplicates" 
                                         GroupName="CompareMode"
                                         Checked="CompareMode_Changed"/>
                        </StackPanel>

                        <!-- Compare Two Elements Panel -->
                        <StackPanel x:Name="CompareTwoPanel" Grid.Row="2" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal">
                            <TextBlock Text="Element 1 ID:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="CompareElement1TextBox" Width="120" Padding="8,6"/>
                            <TextBlock Text="Element 2 ID:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                            <TextBox x:Name="CompareElement2TextBox" Width="120" Padding="8,6"/>
                            <Button Content="⚖️ Compare" Margin="16,0,0,0"
                                    Style="{StaticResource ActionButtonStyle}" Click="CompareTwoButton_Click"/>
                        </StackPanel>

                        <!-- Find Empty Panel -->
                        <StackPanel x:Name="FindEmptyPanel" Grid.Row="2" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="Parameters:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="EmptyParamCombo" Width="200" Padding="8,6"/>
                            <Button Content="🔍 Find Empty" Margin="16,0,0,0"
                                    Style="{StaticResource ActionButtonStyle}" Click="FindEmptyButton_Click"/>
                        </StackPanel>

                        <!-- Find Duplicates Panel -->
                        <StackPanel x:Name="FindDuplicatesPanel" Grid.Row="2" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="Parameter:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="DuplicateParamCombo" Width="200" Padding="8,6"/>
                            <Button Content="🔍 Find Duplicates" Margin="16,0,0,0"
                                    Style="{StaticResource ActionButtonStyle}" Click="FindDuplicatesButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Compare Results -->
                <Border Grid.Row="1" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,12,12,8">
                            <TextBlock x:Name="CompareResultHeader" Text="Results" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CompareResultSummary" Text="" Foreground="#757575" Margin="12,0,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="CompareDataGrid" Grid.Row="1" Margin="8,0,8,8"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Parameter" Binding="{Binding ParameterName}" Width="200"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="50"/>
                                <DataGridTextColumn Header="Value 1" Binding="{Binding Value1}" Width="*"/>
                                <DataGridTextColumn Header="Value 2" Binding="{Binding Value2}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusIcon}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,8" HorizontalAlignment="Right">
                            <Button Content="📋 Select Elements" Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="SelectCompareElementsButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Tab 5: Validate -->
            <Grid x:Name="ValidatePanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Validation Rules -->
                <Border Grid.Column="0" Background="White" CornerRadius="4" Margin="0,0,8,0"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,12,12,8">
                            <TextBlock Text="Validation Rules" FontWeight="SemiBold" FontSize="14"/>
                            <Button Content="➕" Margin="8,0,0,0" Padding="6,2" Background="#4CAF50" 
                                    Foreground="White" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Add Rule" Click="AddRuleButton_Click"/>
                        </StackPanel>

                        <ListBox x:Name="ValidationRulesList" Grid.Row="1" Margin="8,0,8,8" BorderThickness="0"
                                 SelectionChanged="ValidationRulesList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}" 
                                                  Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ParameterName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TypeDisplay}" FontSize="11" Foreground="#757575"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding SeverityIcon}" FontSize="14"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,8" HorizontalAlignment="Center">
                            <Button Content="✅ Run Validation" Style="{StaticResource SuccessButtonStyle}" 
                                    Click="RunValidationButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right: Validation Results -->
                <Border Grid.Column="1" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="12,12,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="ValidationReportHeader" Text="Validation Report" 
                                           FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="ValidationReportSummary" Text="Run validation to see results" 
                                           FontSize="12" Foreground="#757575"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Background="#FFEBEE" CornerRadius="4" Padding="8,4" Margin="4,0">
                                    <TextBlock x:Name="ErrorCountText" Text="🔴 0" FontSize="12"/>
                                </Border>
                                <Border Background="#FFF8E1" CornerRadius="4" Padding="8,4" Margin="4,0">
                                    <TextBlock x:Name="WarningCountText" Text="🟡 0" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <DataGrid x:Name="ValidationDataGrid" Grid.Row="1" Margin="8,0,8,8"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding SeverityIcon}" Width="30"/>
                                <DataGridTextColumn Header="Element" Binding="{Binding ElementName}" Width="180"/>
                                <DataGridTextColumn Header="ID" Binding="{Binding ElementId}" Width="80"/>
                                <DataGridTextColumn Header="Parameter" Binding="{Binding ParameterName}" Width="150"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding CurrentValue}" Width="120"/>
                                <DataGridTextColumn Header="Issue" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,8" HorizontalAlignment="Right">
                            <Button Content="📋 Select All Issues" Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="SelectAllIssuesButton_Click"/>
                            <Button Content="📄 Export Report" Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="ExportReportButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="LoadingText" Text="Loading..." FontSize="16" 
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" 
                           VerticalAlignment="Center" Foreground="#757575"/>
                
                <Button Grid.Column="1" Content="Close" Padding="20,8"
                        Style="{StaticResource ActionButtonStyle}" Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
