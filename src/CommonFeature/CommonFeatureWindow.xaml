<Window x:Class="CommonFeature.CommonFeatureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Common Feature" 
        Height="420" 
        Width="320"
        MinHeight="380"
        MinWidth="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="False"
        Background="#FAFAFA"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16" Background="#3F51B5">
            <StackPanel>
                <TextBlock Text="Common Feature" 
                           FontSize="20" 
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock Text="Select a tool to get started" 
                           FontSize="12" 
                           Foreground="#BBDEFB"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Feature Buttons -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,12">
            <StackPanel>
                <!-- Isolate Button -->
                <Button Margin="0,4" Height="56" 
                        HorizontalContentAlignment="Left"
                        Command="{Binding IsolateCommand}"
                        ToolTip="Isolate elements by category, family, type">
                    <Grid Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" 
                                Background="#E8EAF6" 
                                CornerRadius="8" 
                                Width="44" Height="44"
                                Margin="0,0,14,0">
                            <TextBlock Text="👁" FontSize="20" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Isolate" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Filter and isolate elements" 
                                       FontSize="11" 
                                       Foreground="#757575"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="›" FontSize="20" 
                                   VerticalAlignment="Center" Foreground="#BDBDBD"/>
                    </Grid>
                </Button>

                <!-- Get Information Button -->
                <Button Margin="0,4" Height="56"
                        HorizontalContentAlignment="Left"
                        Command="{Binding GetInformationCommand}"
                        ToolTip="View and edit element information">
                    <Grid Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" 
                                Background="#E3F2FD" 
                                CornerRadius="8" 
                                Width="44" Height="44"
                                Margin="0,0,14,0">
                            <TextBlock Text="ℹ" FontSize="20" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Get Information" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="View element details" 
                                       FontSize="11" 
                                       Foreground="#757575"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="›" FontSize="20" 
                                   VerticalAlignment="Center" Foreground="#BDBDBD"/>
                    </Grid>
                </Button>

                <!-- Show Parameter Button -->
                <Button Margin="0,4" Height="56"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowParameterCommand}"
                        ToolTip="Display all parameters of selected elements">
                    <Grid Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" 
                                Background="#E8F5E9" 
                                CornerRadius="8" 
                                Width="44" Height="44"
                                Margin="0,0,14,0">
                            <TextBlock Text="📋" FontSize="20" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Show Parameter" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="List all parameters" 
                                       FontSize="11" 
                                       Foreground="#757575"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="›" FontSize="20" 
                                   VerticalAlignment="Center" Foreground="#BDBDBD"/>
                    </Grid>
                </Button>

                <!-- Show Boundary Button -->
                <Button Margin="0,4" Height="56"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowBoundaryCommand}"
                        ToolTip="Create section box around selected elements">
                    <Grid Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" 
                                Background="#FFF3E0" 
                                CornerRadius="8" 
                                Width="44" Height="44"
                                Margin="0,0,14,0">
                            <TextBlock Text="📦" FontSize="20" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Section Box" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Create bounding box" 
                                       FontSize="11" 
                                       Foreground="#757575"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="›" FontSize="20" 
                                   VerticalAlignment="Center" Foreground="#BDBDBD"/>
                    </Grid>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" 
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Status Icon -->
                <TextBlock Grid.Column="0" Text="✓" FontSize="14"
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           Foreground="#757575"/>
                
                <!-- Status Message -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#757575"/>
                
                <!-- Loading Indicator -->
                <ProgressBar Grid.Column="2"
                             Width="18" Height="18"
                             IsIndeterminate="True"
                             Margin="10,0,0,0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </Grid>
        </Border>
    </Grid>
</Window>
