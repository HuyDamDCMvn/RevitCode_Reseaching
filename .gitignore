# ============================================================================
# Git Ignore for HD Extension
# ============================================================================

# Build outputs
**/bin/
**/obj/
*.dll
*.pdb
*.exe

# IDE
.vs/
.vscode/
*.user
*.suo
*.cache

# Release & distribution (don't commit binaries/packages)
/release/
/dist/

# Python
__pycache__/
*.pyc
*.pyo

# OS
.DS_Store
Thumbs.db

# Temporary
*.tmp
*.temp
*.log

# Keep these in HD.extension (development)
!HD.extension/lib/net8/*.dll

# But ignore these large files if added accidentally
HD.extension/lib/net8/MaterialDesign*.dll
HD.extension/lib/net8/Microsoft.Xaml.Behaviors.dll

# Local workspace artifacts
SampleDrawing/
.cursor/worktrees.json
