from typing import Tuple, Set, Iterable, List


class ILibraryLoader:
    def LoadNodeLibrary(self, library: Assembly) -> None: ...


class TypedParameter:
    @overload
    def __init__(self, name: str, TypeName: str, TypeRank: int, defaultValue: str, summary: str): ...
    @overload
    def __init__(self, name: str, type: Type, defaultValue: AssociativeNode, shortArgumentName: str, summary: str): ...
    @overload
    def __init__(self, name: str, type: Type, defaultValue: AssociativeNode, shortArgumentName: str, summary: str, nameIsValid: bool): ...
    @property
    def NameIsValid(self) -> bool: ...
    @property
    def Function(self) -> FunctionDescriptor: ...
    @property
    def Name(self) -> str: ...
    @property
    def Type(self) -> Type: ...
    @property
    def DefaultValue(self) -> AssociativeNode: ...
    @property
    def DefaultValueString(self) -> str: ...
    @property
    def Summary(self) -> str: ...
    @property
    def Description(self) -> str: ...
    @property
    def DisplayTypeName(self) -> str: ...
    def ToString(self) -> str: ...
