    def remove_CurrentWorkspaceCleared(self, value: Action) -> None: ...
    def add_CurrentWorkspaceClearingStarted(self, value: Action) -> None: ...
    def remove_CurrentWorkspaceClearingStarted(self, value: Action) -> None: ...
    def add_CurrentWorkspaceOpened(self, value: Action) -> None: ...
