    @property
    def Height(self) -> float: ...
    @Height.setter
    def Height(self, value: float) -> None: ...
    @property
    def Rect(self) -> Rect2D: ...
    @property
    def CenterX(self) -> float: ...
    @CenterX.setter
    def CenterX(self, value: float) -> None: ...
    @property
    def CenterY(self) -> float: ...
    @CenterY.setter
    def CenterY(self, value: float) -> None: ...
    def ReportPosition(self) -> None: ...


class NodeGraph:
    @property
    def Nodes(self) -> List: ...
    @property
    def Connectors(self) -> List: ...
    @property
    def Notes(self) -> List: ...
    @property
    def Annotations(self) -> List: ...
    @property
    def ElementResolver(self) -> ElementResolver: ...
    @property
    def Presets(self) -> List: ...
    def LoadNodeFromXml(elNode: XmlElement, context: SaveContext, nodeFactory: NodeFactory, resolver: ElementResolver) -> NodeModel: ...
    def LoadConnectorFromXml(connEl: XmlElement, nodes: IDictionary) -> ConnectorModel: ...
    def LoadNoteFromXml(note: XmlNode) -> NoteModel: ...
    def LoadPresetsFromXml(xmlDoc: XmlDocument, nodesInNodeGraph: Iterable[NodeModel]) -> Iterable[PresetModel]: ...
    def LoadGraphFromXml(xmlDoc: XmlDocument, nodeFactory: NodeFactory) -> NodeGraph: ...
